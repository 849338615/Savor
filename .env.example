# ============================================================================
# Savor — environment variables
# Copy to `.env.local` and fill in to enable live recipe extraction.
# ============================================================================

# --- Provider selection -----------------------------------------------------
# auto (default) — real provider if a search key is set, else mock
# real           — force real provider (errors at runtime if no search key)
# mock           — force mock provider (the in-repo dataset, no API calls)
RECIPE_PROVIDER=auto


# --- Search backend (pick one) ---------------------------------------------
# Brave Search API — generous free tier (~2,000 queries / month).
# Get a key: https://api-dashboard.search.brave.com/
BRAVE_API_KEY=

# SerpAPI Google — paid, most reliable Google scraper.
# Get a key: https://serpapi.com/
# Used only if BRAVE_API_KEY is unset.
SERPAPI_KEY=


# --- LLM fallback (Anthropic Claude) ---------------------------------------
# Used when a recipe page does not publish Schema.org JSON-LD. Without this,
# the pipeline silently drops pages that lack structured data — most editorial
# sites publish JSON-LD, so the app still works without it, just with fewer
# results from blogs and smaller publications.
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the extraction model. Defaults to claude-opus-4-7.
# For high-volume use, claude-haiku-4-5 is much cheaper and plenty capable
# for structured extraction.
# RECIPE_LLM_MODEL=claude-opus-4-7
